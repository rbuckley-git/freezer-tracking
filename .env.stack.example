# Stack metadata
STACK_NAME=freezer-tracking

# Images
DB_IMAGE=postgres:16
API_IMAGE=registry.example.com/freezer-tracking-api:latest
WEB_IMAGE=registry.example.com/freezer-tracking-web:latest

# Published ports
DB_PUBLISHED_PORT=5434
API_PUBLISHED_PORT=9080
WEB_PUBLISHED_PORT=10000

# Replica counts
API_REPLICAS=1
WEB_REPLICAS=1

# Database
POSTGRES_DB=freezer_tracking
POSTGRES_USER=freezer_tracking
POSTGRES_PASSWORD=change-me-db-password
DATABASE_URL=jdbc:postgresql://db:5432/freezer_tracking
DATABASE_USERNAME=freezer_tracking
DATABASE_PASSWORD=change-me-db-password

# API
PASSWORD_PEPPER=change-me-pepper
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_HOUSE_NAME=Admin House
BOOTSTRAP_ADMIN_EXIT_AFTER_RUN=true

# Web
API_BASE_URL=http://api:9080
COOKIE_KEY=0123456789123456
WEB_PORT=10000
